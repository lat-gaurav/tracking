# ── All downloadable assets (videos, weights, recordings) ─────────────────────
resources/

# ── Stray binary files (safety net outside resources/) ────────────────────────
*.mp4
*.avi
*.mov
*.mkv
*.yuy2
*.pt
*.pth
*.engine
*.onnx
*.trt
*.wts

# ── Snapshots / output images ─────────────────────────────────────────────────
snap_*.png
*.jpg
*.jpeg
*.png

# ── Python runtime ────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# ── Virtual environment ───────────────────────────────────────────────────────
tracking/
.venv/
venv/
env/

# ── Logs / misc ───────────────────────────────────────────────────────────────
*.log
.DS_Store
.idea/
.vscode/
*.swp

# ── Google Drive upload credentials (never commit these) ──────────────────────
credentials.json
token.json
resources.zip

# ── pysot compiled extensions (Cython) ────────────────────────────────────────
siamese/pysot/pysot/utils/region_py/*.c
siamese/pysot/pysot/utils/region_py/*.so

# ── Keep directory structure but not contents ─────────────────────────────────
# (these are recreated by setup_assets.py)
video_test/.gitkeep
models/.gitkeep
